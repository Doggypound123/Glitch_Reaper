{
  "manifest_version": 3,

  "name": "Glitch Reaper",
  "version": "1.0",

  "description": "Automatically records browser activity and creates bug reports.",

  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "downloads",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}